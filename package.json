{
  "name": "sandcastle",
  "version": "1.0.0",
  "description": "",
  "main": "src/hello.ts",
  "scripts": {
    "test": "vitest run",
    "check": ".sandcastle/bin/biome check --write",
    "lint": ".sandcastle/bin/biome lint",
    "format": ".sandcastle/bin/biome format --write",
    "build:sc-image": "sandcastle docker build-image --dockerfile .sandcastle/Containerfile",
    "sc": "tsx .sandcastle/main.mts",
    "sandcastle:cleanup": "bd label list-all | grep 'sandcastle:' | while IFS= read -r label; do bd label remove \"$label\"; done",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "packageManager": "pnpm@10.32.1",
  "license": "ISC",
  "pnpm": {
    "patchedDependencies": {
      "@ai-hero/sandcastle@0.5.10": "patches/@ai-hero__sandcastle@0.5.10.patch"
    }
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.5.10",
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3",
    "zx": "^8.8.5"
  }
}
